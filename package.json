{
  "name": "agendamento-descarga-deploy-root",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./node_modules/prisma/build/index.js generate --schema=backend/prisma/schema.prisma",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "postinstall": "node ./node_modules/prisma/build/index.js generate --schema=backend/prisma/schema.prisma",
    "setup": "npm install && npm run build",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate --schema=backend/prisma/schema.prisma",
    "prisma:push": "node ./node_modules/prisma/build/index.js db push --schema=backend/prisma/schema.prisma",
    "prisma:seed": "node backend/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "1.4.5-lts.2",
    "nodemailer": "^6.9.15",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
