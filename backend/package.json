{
  "name": "agendamento-descarga-v3-operacional",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "node prisma/seed.js",
    "setup": "npm install && prisma generate",
    "build": "node ./node_modules/prisma/build/index.js generate",
    "postinstall": "node ./node_modules/prisma/build/index.js generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "1.4.5-lts.2",
    "nodemailer": "^6.9.15",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
