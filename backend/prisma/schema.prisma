generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senhaHash String
  perfil    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fornecedor {
  id        Int      @id @default(autoincrement())
  nome      String
  cnpj      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transportadora {
  id        Int      @id @default(autoincrement())
  nome      String
  cnpj      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Motorista {
  id             Int      @id @default(autoincrement())
  nome           String
  cpf            String?
  transportadora String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Veiculo {
  id             Int      @id @default(autoincrement())
  placa          String
  tipo           String?
  transportadora String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Doca {
  id        Int      @id @default(autoincrement())
  codigo    String
  descricao String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Janela {
  id        Int      @id @default(autoincrement())
  codigo    String
  descricao String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Regra {
  id                       Int      @id @default(autoincrement())
  nome                     String
  toleranciaAtrasoMin      Int      @default(15)
  tempoDescargaPrevistoMin Int      @default(60)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Agendamento {
  id                 Int         @id @default(autoincrement())
  protocolo          String      @unique
  checkinToken       String      @unique
  fornecedor         String
  transportadora     String
  motorista          String
  placa              String
  doca               String?
  janela             String?
  dataAgendada       String
  horaAgendada       String
  quantidadeNotas    Int         @default(0)
  quantidadeVolumes  Int         @default(0)
  status             String      @default("PENDENTE_APROVACAO")
  observacoes        String?
  motivoReprovacao   String?
  motivoCancelamento String?
  inicioDescargaEm   DateTime?
  fimDescargaEm      DateTime?
  checkinEm          DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  documentos         Documento[]
}

model Documento {
  id            Int        @id @default(autoincrement())
  agendamentoId Int
  tipoDocumento String
  nomeArquivo   String
  urlArquivo    String
  createdAt     DateTime   @default(now())
  agendamento   Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
}
