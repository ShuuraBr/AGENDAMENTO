# ─── Server ───
PORT=3000
NODE_ENV=development

# ─── Security (REQUIRED in production) ───
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ─── CORS ───
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ─── Rate Limiting ───
RATE_LIMIT_MAX=300

# ─── Database ───
DATABASE_URL=mysql://user:password@localhost:3306/agendamento
# Or individual variables:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=user
# DB_PASS=password
# DB_NAME=agendamento

# ─── SMTP / Email ───
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
SMTP_RETRY_ATTEMPTS=3
SMTP_RETRY_DELAY_MS=1200

# ─── WhatsApp (optional) ───
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=stub
WHATSAPP_TOKEN=
WHATSAPP_BASE_URL=

# ─── Upload limits ───
UPLOAD_DIR=uploads
DOCUMENT_MAX_BYTES=10485760
AVARIA_IMAGE_MAX_BYTES=5242880
AVARIA_IMAGE_MAX_COUNT=10

# ─── Seed ───
# Set a strong password for the admin seed user (random if omitted)
SEED_ADMIN_PASSWORD=

# ─── Financial monitoring ───
FINANCEIRO_EMAIL=
MONTHLY_DIGEST_AUTOMATIC_DAY_LIMIT=3

# ─── Relatorio watcher ───
RELATORIO_IMPORT_WATCHER=0
